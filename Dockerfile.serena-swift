# Swift language server extension — opt-in for repos with swift in .serena/project.yml
# Extends the base serena-local image; NOT included by default.
# Trigger: add '- swift' to languages: in .serena/project.yml, then run setup.sh.
#
# Architecture: sourcekit-lsp is a macOS binary (/usr/bin/sourcekit-lsp) — it cannot
# run inside this Linux container. The host machine exposes sourcekit-lsp through a
# Unix domain socket. This image installs socat and a shim that connects Serena's LSP
# calls through that socket.
#
# Host setup (handled automatically by scripts/serena-docker):
#   socat UNIX-LISTEN:/tmp/serena-swift-<repo>.sock,fork EXEC:/usr/bin/sourcekit-lsp
#
# Container shim (/usr/local/bin/sourcekit-lsp):
#   Startup retry loop — retries socat connect up to 15× with back-off (~30s window).
#   Exits 0 after a successful connection closes (Serena restarts us if needed via
#   LanguageServerManager._ensure_functional_ls). Exits 1 if socket never appears.
#
# Zero-trust parity: the socket is a narrow JSON-RPC pipe. The container gains no
# new capabilities beyond Swift symbol resolution. execute_shell_command remains
# excluded; all project files remain read-only.
ARG LOCAL_TAG=latest
FROM serena-local:${LOCAL_TAG}

# --- socat: bridges container stdin/stdout to the host Unix domain socket ---
RUN apt-get update \
    && apt-get install -y --no-install-recommends socat \
    && rm -rf /var/lib/apt/lists/*

# --- sourcekit-lsp shim: Serena invokes this as if it were the real LSP binary ---
# Connects to the socket the host created at /tmp/sourcekit-lsp.sock.
# Probe guard: Serena calls `sourcekit-lsp -h` at startup to verify the binary
# is available before opening an LSP session. Without this guard, the shim would
# connect to the socket (spawning a real sourcekit-lsp on the host) and block
# indefinitely — the probe would time out and Serena would mark Swift LSP as failed.
RUN printf '%s\n' \
      '#!/bin/sh' \
      '# Probe guard: exit immediately for capability-check invocations.' \
      '# Serena uses -h to verify the binary exists; it expects a quick exit, not LSP.' \
      'case "${1:-}" in' \
      '  -h|--help|--version) exit 0 ;;' \
      'esac' \
      '# Startup retry loop: up to 15 attempts (~30s) for the host socat to bind.' \
      '# socat exits 1 on ECONNREFUSED, exits 0 on clean connection close.' \
      '# After a successful connection, exit and let Serena restart us if needed.' \
      '_delay=1; _attempts=0; _max=15' \
      'while [ "${_attempts}" -lt "${_max}" ]; do' \
      '  socat - UNIX-CONNECT:/tmp/sourcekit-lsp.sock' \
      '  [ "$?" -eq 0 ] && exit 0' \
      '  _attempts=$(( _attempts + 1 ))' \
      '  sleep "${_delay}"' \
      '  [ "${_delay}" -lt 4 ] && _delay=$(( _delay + 1 ))' \
      'done' \
      'exit 1' \
      > /usr/local/bin/sourcekit-lsp \
    && chmod +x /usr/local/bin/sourcekit-lsp
