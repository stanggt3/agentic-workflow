#!/usr/bin/env bash
# Serena MCP wrapper — mounts current repo into the container at invocation time.
# Claude Code spawns this from the project directory, so $(pwd) == repo root.
# To upgrade: update BASE_VERSION= here and ARG BASE_TAG in Dockerfile.serena — one each.
# Note: ghcr.io/oraios/serena only publishes :latest (no versioned tags). BASE_VERSION
# controls the local image name (serena-local:$BASE_VERSION) for cache invalidation.
set -euo pipefail

REPO_PATH="$(pwd)"
REPO_NAME="$(printf '%s' "$(basename "$REPO_PATH")" | tr -c '[:alnum:]-_.' '-')"   # sanitize; printf avoids trailing newline → trailing '-' bug
CONTAINER_NAME="serena-${REPO_NAME}"                 # stable name enables pre-flight eviction on restart
BASE_VERSION="latest"                                 # single source of truth for version

# Select image based on repo's declared languages in .serena/project.yml
# Repos with 'csharp' in their languages list use the C# extension image
IMAGE="serena-local:${BASE_VERSION}"
if [ -f "${REPO_PATH}/.serena/project.yml" ] && grep -qE '^[[:space:]]*-[[:space:]]*csharp([[:space:]]|$)' "${REPO_PATH}/.serena/project.yml"; then
  IMAGE="serena-local:${BASE_VERSION}-csharp"
fi

# Fail fast with a clear error if the required image hasn't been built yet
if [[ -z "$(docker images -q "${IMAGE}" 2>/dev/null)" ]]; then
  echo "ERROR: ${IMAGE} not found. Run setup.sh to build it." >&2
  if [[ "${IMAGE}" == *-csharp ]]; then
    echo "       C# image is built separately. setup.sh handles this automatically." >&2
  fi
  exit 1
fi

mkdir -p "${REPO_PATH}/.serena/cache" "${REPO_PATH}/.serena/logs" "${REPO_PATH}/.serena/memory"

# ---------------------------------------------------------------------------
# Swift LSP bridge: sourcekit-lsp runs on the macOS host; the container talks
# to it through a Unix domain socket mounted into the container.
#
# When .serena/project.yml declares '- swift' in its languages list:
#   1. Host-side: socat listens on a per-project socket and spawns sourcekit-lsp
#      for each connection (fork mode, so Serena can reconnect after crashes).
#   2. Container-side: /usr/local/bin/sourcekit-lsp shim (in serena-local:*-swift)
#      connects its stdin/stdout to the socket via UNIX-CONNECT.
#   3. The socket file is mounted into the container at /tmp/sourcekit-lsp.sock.
#
# Zero-trust parity: only JSON-RPC passes through the socket. The container
# gains no shell access. execute_shell_command remains excluded in project.yml.
# ---------------------------------------------------------------------------
SWIFT_SOCAT_PID=""
SOCKET_PATH=""

if [ -f "${REPO_PATH}/.serena/project.yml" ] && grep -qE '^[[:space:]]*-[[:space:]]*swift([[:space:]]|$)' "${REPO_PATH}/.serena/project.yml"; then
  if ! command -v socat &>/dev/null; then
    echo "WARN: 'socat' not found — Swift LSP bridge disabled. Install with: brew install socat" >&2
    echo "WARN: Serena will start without Swift LSP support." >&2
  elif ! command -v sourcekit-lsp &>/dev/null; then
    echo "WARN: 'sourcekit-lsp' not found — Swift LSP bridge disabled. Xcode required." >&2
    echo "WARN: Serena will start without Swift LSP support." >&2
  else
    # Check for the swift image; fall back to standard if not built yet
    SWIFT_IMAGE="serena-local:${BASE_VERSION}-swift"
    if [[ -z "$(docker images -q "${SWIFT_IMAGE}" 2>/dev/null)" ]]; then
      echo "WARN: ${SWIFT_IMAGE} not found — run BUILD_SWIFT=1 ./setup.sh to build it." >&2
      echo "WARN: Falling back to standard Serena image without Swift LSP support." >&2
    else
      IMAGE="${SWIFT_IMAGE}"
      SOCKET_PATH="/tmp/serena-swift-${REPO_NAME}.sock"

      # R1: Evict any prior container that still holds the old socket inode.
      # Without this, the running container's bind-mount points to the old inode
      # even after we delete/recreate the socket file (Docker captures the inode
      # at mount time). The container would see ECONNREFUSED forever.
      if docker inspect "${CONTAINER_NAME}" &>/dev/null; then
        echo "Stopping prior Serena container '${CONTAINER_NAME}' (stale socket inode) ..." >&2
        docker stop "${CONTAINER_NAME}" 2>/dev/null || true
        docker rm   "${CONTAINER_NAME}" 2>/dev/null || true
      fi

      # R1: Kill any orphaned host socat from a prior session (its wrapper exited
      # but socat kept running, holding the old inode open as an unlinked file).
      # Use SIGKILL (-9) so the process is gone before we rm the socket; SIGTERM
      # leaves a window where a new socat can start before the old one exits,
      # producing duplicate listeners.
      pkill -9 -f "socat.*UNIX-LISTEN:${SOCKET_PATH}" 2>/dev/null || true
      # Brief wait for the kernel to reclaim the socket inode from the killed process
      sleep 0.1

      # Remove any stale socket file so the new socat gets a clean bind
      rm -f "${SOCKET_PATH}"

      # Launch host-side bridge: accepts connections on the socket, forks sourcekit-lsp
      socat "UNIX-LISTEN:${SOCKET_PATH},reuseaddr,fork" \
            "EXEC:$(command -v sourcekit-lsp)" &
      SWIFT_SOCAT_PID=$!

      # R2: Wait for socat to bind the socket (up to 10s) instead of a fixed sleep.
      # On a fast machine this completes in <0.1s; the budget covers slow/loaded hosts.
      _sw=0; _sw_max=50   # 50 × 0.2s = 10s
      while [ ! -S "${SOCKET_PATH}" ] && [ "${_sw}" -lt "${_sw_max}" ]; do
        sleep 0.2
        _sw=$(( _sw + 1 ))
      done

      if [ ! -S "${SOCKET_PATH}" ] || ! kill -0 "${SWIFT_SOCAT_PID}" 2>/dev/null; then
        echo "WARN: Swift LSP bridge failed to bind within 10s. Falling back to standard image." >&2
        IMAGE="serena-local:${BASE_VERSION}"
        SOCKET_PATH=""
        SWIFT_SOCAT_PID=""
      else
        echo "Swift LSP bridge active (pid=${SWIFT_SOCAT_PID}, socket=${SOCKET_PATH})" >&2
      fi
    fi
  fi
fi

# Kill the host-side socat when the container exits (covers normal exit and signals)
cleanup() {
  if [ -n "${SWIFT_SOCAT_PID}" ]; then
    kill "${SWIFT_SOCAT_PID}" 2>/dev/null || true
    rm -f "${SOCKET_PATH}" 2>/dev/null || true
  fi
}
trap cleanup EXIT

# Build docker run options (bash 3-compatible array approach)
DOCKER_OPTS=(
  "--name" "${CONTAINER_NAME}" "--rm" "-i"
  "-v" "${REPO_PATH}:/workspaces/projects/${REPO_NAME}:ro"
  "-v" "${REPO_PATH}/.serena/cache:/workspaces/projects/${REPO_NAME}/.serena/cache"
  "-v" "${REPO_PATH}/.serena/logs:/workspaces/projects/${REPO_NAME}/.serena/logs"
  "-v" "${REPO_PATH}/.serena/memory:/workspaces/projects/${REPO_NAME}/.serena/memory"
)
if [ -n "${SOCKET_PATH}" ]; then
  DOCKER_OPTS+=("-v" "${SOCKET_PATH}:/tmp/sourcekit-lsp.sock")
fi

docker run "${DOCKER_OPTS[@]}" \
  "${IMAGE}" \
  serena start-mcp-server \
  --context claude-code \
  --project "/workspaces/projects/${REPO_NAME}"
