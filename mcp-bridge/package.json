{
  "name": "@agentic-workflow/mcp-bridge",
  "version": "1.0.0",
  "description": "MCP server for bidirectional Claude Code / Codex multi-agent communication",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
